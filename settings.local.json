{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/.claude/hooks/block-rm.js"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__supabase__list_tables",
      "mcp__supabase__get_publishable_keys",
      "mcp__supabase__get_project_url",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(Remove-Item *)",
      "Bash(rmdir *)",
      "Bash(del *)"
    ]
  },
  "enabledMcpjsonServers": [
    "supabase"
  ]
}
